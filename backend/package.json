{
  "name": "restaurant-reservation-api",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal Express + TypeORM API for Vue/Nuxt evaluation (in-memory SQLite)",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "generate:types": "openapi-typescript http://localhost:3000/openapi.json -o ./openapi.d.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "openapi-typescript": "^7.4.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
